# Copy this file to .env and fill in real values. Never commit .env itself.

PORT=4000
NODE_ENV=development

# The frontend origin allowed to make credentialed requests (CORS).
CLIENT_URL=http://localhost:5173

# Supabase Project -> Settings -> Database -> Connection string (URI, "Session" mode is fine for dev).
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Any long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# Paystack -> Settings -> API Keys & Webhooks -> Secret key. Use the TEST key while developing.
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
